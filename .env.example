# URI namespaces (do not change without surfacing the decision)
BFFI_WORK_NAMESPACE=http://urn.fi/URN:NBN:fi:bib:work:
BFFI_EXPRESSION_NAMESPACE=http://urn.fi/URN:NBN:fi:bib:expression:
BFFI_HELMET_SOURCE_URI=http://urn.fi/URN:NBN:fi:bib:source:helmet
BFFI_GRAPH_BASE=http://urn.fi/URN:NBN:fi:bib:graph:

# Local LLM
# Primary: Qwen3 32B 4-bit. Tag has no "-instruct" infix — Qwen3
# instruct weights are the default published.
# Fallback: Qwen2.5 72B 4-bit. Qwen3 has no 72B size (sizes go
# 0.6b/1.7b/14b/32b/235b), so the cascade fallback steps down to the
# previous-generation 72B that's still Apache 2.0 and similar quality.
LLM_BASE_URL=http://localhost:11434/v1
# Optional per-tier overrides for the M6 cascade. Leave empty (the
# default) when one server hosts both judge models — Ollama serves
# every model from :11434, so LLM_BASE_URL is enough. Populate
# explicitly when each tier runs on its own port — mlx-lm's server
# is one process per model, so the cascade flips between two
# ports (e.g. 8001 primary, 8002 fallback). Plan P-02 § D1.
LLM_BASE_URL_PRIMARY=
LLM_BASE_URL_FALLBACK=
LLM_API_KEY=ollama
LLM_MODEL_PRIMARY=qwen3:32b-q4_K_M
LLM_MODEL_FALLBACK=qwen2.5:72b-instruct-q4_K_M
# Per-call LLM wall-time ceiling (seconds). The M6 cascade retries
# on timeout via the existing 5/30/120 s exponential-backoff stack
# before falling through to 'uncertain'. Watchdog events stream to
# stderr (prefix WATCHDOG_EVENT) and to <BFFI_DATA_DIR>/watchdog-events.jsonl.
# Default 90 s is ~3x the observed median on qwen3:8b. Plan:
# docs/plans/in-progress/p-03-m6-stall-watchdog.md.
LLM_CALL_TIMEOUT_SECONDS=90
# Per-pair wall-time ceiling for the whole M6 cascade (primary +
# fallback + retries). Orthogonal to the per-call ceiling — catches
# the case where many legitimate calls add up to a long pair even
# when no single call exceeds the per-call budget. Pairs that hit
# this ceiling are marked uncertain with bffi-prov:stage=
# "watchdog-aborted" (same as per-call exhaustion).
LLM_PAIR_TIMEOUT_SECONDS=300

# Triple store
FUSEKI_URL=http://localhost:3030/bffi

# Data directories
BFFI_DATA_DIR=./data
BFFI_LOGS_DIR=./logs
BFFI_EVAL_DIR=./eval-runs

# Sierra Postgres replica — only required for `marcxml-export-sierra`
# (the `marcxml_export_pipeline.sierra` exporter). The BFFI pipeline
# itself reads MARCXML from disk and does not touch the ILS.
DB_HOST=
DB_PORT=1032
DB_USER=
DB_PASSWORD=
DB_NAME=iii
# Agency code stamped into MARC 003 when the source row lacks one.
# Defaults to FI-HELME (Helmet) when unset — override per ILS.
MARCXML_EXPORT_AGENCY_CODE=FI-HELME
