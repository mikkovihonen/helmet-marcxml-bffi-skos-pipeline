# config/skosmos-config.ttl
#
# Skosmos vocabulary configuration for the BFFI authority graph
# (M11). Mounted into the Skosmos container at /var/www/html/config.ttl
# by docker-compose.yml. Companion to
# docs/marcxml-to-bffi-skosmos-pipeline.md § 4.
#
# Note on hostnames: this file lives INSIDE the Skosmos container, so
# the SPARQL endpoint URL uses the docker-compose service name
# `fuseki` rather than `localhost`. A user running Skosmos directly
# on the host (no Docker) should swap `http://fuseki:3030/...` for
# `http://localhost:3030/...` here.

@prefix skosmos: <http://purl.org/net/skosmos#> .
@prefix void:    <http://rdfs.org/ns/void#> .
@prefix dc:      <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix bffi:    <http://urn.fi/URN:NBN:fi:schema:bffi:> .
@prefix isothes: <http://purl.org/iso25964/skos-thes#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix :        <#> .

# ---------------------------------------------------------------------------
# Skosmos global configuration. Mirrors the structure of
# `third_party/Skosmos/dockerfiles/config/config-docker-compose.ttl`
# but trimmed to what the BFFI pipeline actually needs. Skosmos refuses
# to start if config.ttl doesn't contain exactly one
# `skosmos:Configuration` resource, so this block is mandatory even
# when the per-vocabulary entry below carries its own SPARQL endpoint.
# ---------------------------------------------------------------------------

:config a skosmos:Configuration ;
    skosmos:sparqlEndpoint    <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect     "JenaText" ;
    skosmos:sparqlTimeout     20 ;
    skosmos:httpTimeout       5 ;
    skosmos:serviceName       "BFFI authority browser" ;
    # UI languages match the BFFI display priority committed in
    # CLAUDE.md: Finnish first, then Swedish, then English.
    skosmos:languages (
        [ rdfs:label "fi" ; rdf:value "fi_FI.utf8" ]
        [ rdfs:label "sv" ; rdf:value "sv_SE.utf8" ]
        [ rdfs:label "en" ; rdf:value "en_GB.utf8" ]
    ) ;
    skosmos:searchResultsSize    20 ;
    skosmos:transitiveLimit      1000 ;
    skosmos:rdfListItemsLimit    1000 ;
    skosmos:logCaughtExceptions  false ;
    skosmos:logBrowserConsole    false ;
    skosmos:templateCache        "/tmp/skosmos-template-cache" ;
    skosmos:customCss            "resource/css/stylesheet.css" ;
    skosmos:feedbackAddress      "" ;
    skosmos:feedbackSender       "" ;
    skosmos:feedbackEnvelopeSender "" ;
    skosmos:uiLanguageDropdown   false ;
    skosmos:uiHoneypotEnabled    true ;
    skosmos:uiHoneypotTime       5 ;
    skosmos:globalPlugins        () .

# ---------------------------------------------------------------------------
# Type labels — Skosmos requires rdfs:label on every custom type so
# the type filter in the UI shows human-readable names. The
# rdfs:subClassOf skos:Concept declarations also live in
# config/overlay/bffi-skos-overlay.ttl; restating them here keeps the
# Skosmos config self-contained for users who load Skosmos config
# without first parsing the bffi-works graph.
# ---------------------------------------------------------------------------

bffi:Work       rdfs:label      "Work"@en, "Teos"@fi, "Verk"@sv ;
                rdfs:subClassOf skos:Concept .

bffi:Expression rdfs:label      "Expression"@en, "Ekspressio"@fi, "Uttryck"@sv ;
                rdfs:subClassOf skos:Concept .

# ---------------------------------------------------------------------------
# Subject categorisation entry — referenced by the vocabulary's
# dc:subject so the Skosmos sidebar can group vocabularies by topic.
# ---------------------------------------------------------------------------

:catBibliographic a skosmos:Category ;
    rdfs:label "Bibliographic data"@en,
               "Kirjastoaineisto"@fi,
               "Bibliografisk data"@sv .

# ---------------------------------------------------------------------------
# Fuseki backend — stays on the docker-compose `fuseki` service.
# ---------------------------------------------------------------------------

:bibframeEndpoint a void:Dataset ;
    void:sparqlEndpoint <http://fuseki:3030/bffi/sparql> .

# ---------------------------------------------------------------------------
# The vocabulary entry. Per spec § 4:
#  - void:uriSpace MUST match the canonical Work URI prefix exactly,
#    otherwise Skosmos won't recognise internal links.
#  - skosmos:language order doubles as the display-language priority;
#    "fi", "sv", "en" matches Finland's official languages plus an
#    international fallback.
#  - skosmos:sparqlDialect "JenaText" enables the text:query predicate
#    Skosmos uses for fast label search; without it, search becomes
#    painfully slow at scale. Verify `jena-text` is enabled in the
#    Fuseki image (it is in stain/jena-fuseki:5.0.0).
#  - The two skosmos:indexShowClass entries are the user-facing type
#    filter committed in BUILD_PLAN M11.
# ---------------------------------------------------------------------------

:bffiWorks a skosmos:Vocabulary, void:Dataset ;
    dc:title          "Finnish Authority Works and Expressions"@en,
                      "Suomalaiset auktoriteettiteokset ja -ekspressiot"@fi,
                      "Finska auktoritetsverk och uttryck"@sv ;
    skosmos:shortName "bffi-works"@en ;
    dc:subject        :catBibliographic ;
    void:uriSpace     "http://urn.fi/URN:NBN:fi:bib:work:" ;

    skosmos:language        "fi", "sv", "en" ;
    skosmos:defaultLanguage "fi" ;

    skosmos:sparqlGraph     <http://urn.fi/URN:NBN:fi:bib:graph:bffi-works> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;

    # The two custom types the user can filter by from the type dropdown.
    skosmos:indexShowClass  bffi:Work ;
    skosmos:indexShowClass  bffi:Expression ;

    # Group view — Works clustered with their Expressions via
    # skos:narrower (lifted from bffi:hasExpression by the Skosify overlay).
    skosmos:groupClass      isothes:ConceptGroup ;

    skosmos:showTopConcepts       true ;
    skosmos:fullAlphabeticalIndex true .

# ---------------------------------------------------------------------------
# Finto-hosted vocabularies (KANTO/YSO/KAUNO/MUSO/SLM) — option 3b.
#
# M9 reconciliation binds canonical-Work creators to KANTO and subjects/
# genre-forms to YSO/KAUNO/MUSO/SLM URIs. To make those URIs render as
# labelled, clickable links in the Skosmos UI, we load the canonical
# Turtle dumps from api.finto.fi into our own Fuseki under each vocab's
# concept-scheme URI as the named graph (run via `bffi-pipeline
# load-finto` / `make refresh-finto`). The vocab declarations below tell
# Skosmos how to route URIs in the matching `void:uriSpace` to the right
# vocab page on our instance, and which named graph to query for labels.
#
# Per-vocab `skosmos:language` lists match each vocab's actual coverage
# (KANTO is fi-only; YSO adds `se`/Sami; KAUNO adds `en`). The shared
# Fuseki SPARQL endpoint + `JenaText` dialect mirror the bffiWorks vocab
# above so every vocab gets fast `text:query` label search.
# ---------------------------------------------------------------------------

:yso a skosmos:Vocabulary, void:Dataset ;
    dc:title          "YSO — General Finnish Ontology"@en,
                      "YSO — Yleinen suomalainen ontologia"@fi,
                      "YSO — Allmän finländsk ontologi"@sv ;
    skosmos:shortName "yso"@en ;
    void:uriSpace     "http://www.yso.fi/onto/yso/" ;
    skosmos:language        "fi", "sv", "en", "se" ;
    skosmos:defaultLanguage "fi" ;
    skosmos:sparqlGraph     <http://www.yso.fi/onto/yso/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:showTopConcepts       true ;
    skosmos:fullAlphabeticalIndex true .

:kanto a skosmos:Vocabulary, void:Dataset ;
    dc:title          "KANTO — Finnish national name authorities"@en,
                      "KANTO — Kansalliset toimijatiedot"@fi ;
    skosmos:shortName "kanto"@en ;
    void:uriSpace     "http://urn.fi/URN:NBN:fi:au:finaf:" ;
    skosmos:language        "fi" ;
    skosmos:defaultLanguage "fi" ;
    skosmos:sparqlGraph     <http://urn.fi/URN:NBN:fi:au:finaf:> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:fullAlphabeticalIndex true .

:kauno a skosmos:Vocabulary, void:Dataset ;
    dc:title          "KAUNO — Ontology of fictive subjects"@en,
                      "KAUNO — Fiktiivisen aineiston ontologia"@fi,
                      "KAUNO — Ontologi för fiktiva ämnesord"@sv ;
    skosmos:shortName "kauno"@en ;
    void:uriSpace     "http://www.yso.fi/onto/kauno/" ;
    skosmos:language        "fi", "sv", "en" ;
    skosmos:defaultLanguage "fi" ;
    skosmos:sparqlGraph     <http://www.yso.fi/onto/kauno/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:showTopConcepts       true ;
    skosmos:fullAlphabeticalIndex true .

:muso a skosmos:Vocabulary, void:Dataset ;
    dc:title          "MUSO — Music ontology"@en,
                      "MUSO — Musiikin ontologia"@fi,
                      "MUSO — Musikontologi"@sv ;
    skosmos:shortName "muso"@en ;
    void:uriSpace     "http://www.yso.fi/onto/muso/" ;
    skosmos:language        "fi", "sv" ;
    skosmos:defaultLanguage "fi" ;
    skosmos:sparqlGraph     <http://www.yso.fi/onto/muso/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:showTopConcepts       true ;
    skosmos:fullAlphabeticalIndex true .

:slm a skosmos:Vocabulary, void:Dataset ;
    dc:title          "SLM — Finnish genre/form thesaurus"@en,
                      "SLM — Suomalainen lajityyppi- ja muotosanasto"@fi,
                      "SLM — Finsk genre- och formordlista"@sv ;
    skosmos:shortName "slm"@en ;
    void:uriSpace     "http://urn.fi/URN:NBN:fi:au:slm:" ;
    skosmos:language        "fi", "sv" ;
    skosmos:defaultLanguage "fi" ;
    skosmos:sparqlGraph     <http://urn.fi/URN:NBN:fi:au:slm:> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:showTopConcepts       true ;
    skosmos:fullAlphabeticalIndex true .

# LoC MARC Code List for Relators — labels the bf:role URIs emitted by
# the M3 contributor-extraction cascade (e.g. relators/trl for
# translator). English-only; downstream Finnish-UI sessions still
# render the labels because Skosmos falls back when only one language
# is available.
:relators a skosmos:Vocabulary, void:Dataset ;
    dc:title          "MARC Code List for Relators"@en ;
    skosmos:shortName "relators"@en ;
    void:uriSpace     "http://id.loc.gov/vocabulary/relators/" ;
    skosmos:language        "en" ;
    skosmos:defaultLanguage "en" ;
    skosmos:sparqlGraph     <http://id.loc.gov/vocabulary/relators/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:fullAlphabeticalIndex true .

# LC Genre/Form Terms — Helmet cataloguers cite English LCGFT URIs on
# MARC 655 fields (e.g. genreForms/gf2015026020 for "Novels"). Loading
# the dump lets Skosmos render those URIs as labelled clickable
# concepts and lets graph_uri_for_uri recognise them so M9 walkers
# correctly skip them as already-resolved.
:lcgft a skosmos:Vocabulary, void:Dataset ;
    dc:title          "LC Genre/Form Terms"@en ;
    skosmos:shortName "lcgft"@en ;
    void:uriSpace     "http://id.loc.gov/authorities/genreForms/" ;
    skosmos:language        "en" ;
    skosmos:defaultLanguage "en" ;
    skosmos:sparqlGraph     <http://id.loc.gov/authorities/genreForms/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:fullAlphabeticalIndex true .

# LC Subject Headings — the general English subject thesaurus.
# Cataloguers occasionally use $2 lcsh for topical subjects on records
# copied or harmonised from English-language sources. Tier-0 routes
# subject-kind requests through both YSO and LCSH so those English
# literals bind deterministically without a Finto API call.
:lcsh a skosmos:Vocabulary, void:Dataset ;
    dc:title          "LC Subject Headings"@en ;
    skosmos:shortName "lcsh"@en ;
    void:uriSpace     "http://id.loc.gov/authorities/subjects/" ;
    skosmos:language        "en" ;
    skosmos:defaultLanguage "en" ;
    skosmos:sparqlGraph     <http://id.loc.gov/authorities/subjects/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:fullAlphabeticalIndex true .

# KAUNOKKI/BELLA — Finto fiction thesaurus, the legacy KAUNO form with
# Swedish parallel labels under the Bella sub-vocab. Loaded so that
# $2 kaunokki / $2 bella-tagged URIs render as labelled clickable
# concepts in Skosmos.
:kaunokki a skosmos:Vocabulary, void:Dataset ;
    dc:title          "KAUNOKKI/BELLA — fiktiivisen aineiston sanasto"@fi,
                      "KAUNOKKI/BELLA — vocabulary for fictional material"@en ;
    skosmos:shortName "kaunokki"@fi,
                      "kaunokki"@sv,
                      "kaunokki"@en ;
    void:uriSpace     "http://urn.fi/URN:NBN:fi:au:kaunokki:" ;
    skosmos:language        "fi", "sv" ;
    skosmos:defaultLanguage "fi" ;
    skosmos:sparqlGraph     <http://urn.fi/URN:NBN:fi:au:kaunokki:> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:fullAlphabeticalIndex true .

# Allärs — Swedish general subjects thesaurus (Allmän tesaurus på
# svenska). Swedish-language parallel to YSA/YSO; cataloguers tag
# $2 allars on Swedish-language MARC 6XX subjects.
:allars a skosmos:Vocabulary, void:Dataset ;
    dc:title          "Allärs — Allmän tesaurus på svenska"@sv,
                      "Allars — Swedish general thesaurus"@en ;
    skosmos:shortName "allars"@sv,
                      "allars"@en ;
    void:uriSpace     "http://www.yso.fi/onto/allars/" ;
    skosmos:language        "sv" ;
    skosmos:defaultLanguage "sv" ;
    skosmos:sparqlGraph     <http://www.yso.fi/onto/allars/> ;
    skosmos:sparqlEndpoint  <http://fuseki:3030/bffi/sparql> ;
    skosmos:sparqlDialect   "JenaText" ;
    skosmos:fullAlphabeticalIndex true .
