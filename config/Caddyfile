# Caddy reverse-proxy config for the local observability stack.
# Routes three services + a static-file browser behind one port so
# operators only have to remember `http://localhost:8080/`.
#
# Bound to 127.0.0.1 in docker-compose.yml; no auth here (mirrors the
# pre-proxy stance: anonymous Grafana, open Prometheus, local-only
# observability per CLAUDE.md).

:8080 {
	# Sensible logs (errors only — info-level is too chatty for a
	# local dev stack).
	log {
		output stdout
		format console
		level WARN
	}

	# Static file browser over the bind-mounted runs/ directory.
	# `handle_path` strips the /files prefix before the file_server
	# handler matches against the on-disk path, so URLs like
	# `/files/<run_uuid>/canonical-mint-failures.tsv` resolve to
	# `/srv/<run_uuid>/canonical-mint-failures.tsv` inside the
	# container. `browse` turns on directory listings — operators
	# can drill from /files/ down to a specific run.
	handle_path /files/* {
		root * /srv
		file_server browse
	}

	# Grafana. The /grafana prefix is preserved (no strip) because
	# `GF_SERVER_SERVE_FROM_SUB_PATH=true` makes Grafana itself
	# expect to serve under /grafana — that's how its asset URLs,
	# dashboard links, and login redirects stay consistent.
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# Prometheus. Prefix preserved for the same reason — Prometheus
	# is launched with `--web.route-prefix=/prometheus/` so it
	# serves its UI + API under that path natively.
	handle /prometheus/* {
		reverse_proxy prometheus:9090
	}

	# Root → Grafana, the operator's most common destination.
	handle / {
		redir /grafana/ permanent
	}
}
