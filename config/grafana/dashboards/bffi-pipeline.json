  "panels": [
    {
      "id": 9,
      "type": "stat",
      "title": "M2 marc-to-bf",
      "description": "Current state of pipeline stage `m2` for the active run. Green=running, blue=done, grey=idle / not-yet-started. P-12 Phase E.",
      "datasource": {
        "type": "prometheus",
        "uid": "bffi-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(30 * (count(bffi_stage_ended_timestamp{stage=\"m2\",run_uuid=\"$active_run\"}) or on() vector(0)) + 20 * ((count(bffi_stage_started_timestamp{stage=\"m2\",run_uuid=\"$active_run\"}) unless count(bffi_stage_ended_timestamp{stage=\"m2\",run_uuid=\"$active_run\"})) or on() vector(0)) + 10 * ((bffi_stage_planned{stage=\"m2\",run_uuid=\"$active_run\"} unless on(stage, run_uuid) bffi_stage_started_timestamp{stage=\"m2\",run_uuid=\"$active_run\"}) or on() vector(0))) or on() vector(0)",
          "legendFormat": "m2"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none",
        "textMode": "value",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "skipped",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "skipped",
                  "color": "text"
                },
                "10": {
                  "text": "pending",
                  "color": "orange"
                },
                "20": {
                  "text": "running",
                  "color": "green"
                },
                "30": {
                  "text": "done",
                  "color": "blue"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "text",
                "value": null
              }
            ]
          }
        }
      }
    },
