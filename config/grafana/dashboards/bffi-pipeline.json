      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bffi_stage_outcomes_total{stage=\"m9\",run_uuid=\"$active_run\"}",
          "legendFormat": "{{outcome}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "basic"
      }
    },
    {
      "id": 5,
      "type": "state-timeline",
      "title": "Dependency health",
      "description": "Per-(stage, dep) health verdict. P-12 Phase C: series whose most recent probe is older than 60s are filtered out by the freshness clause so the timeline shows a gap (grey) instead of extending stale state indefinitely. P-12 Phase B: not_configured deps (NaN gauge) render as grey too.",
      "datasource": {
        "type": "prometheus",
        "uid": "bffi-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bffi_dependency_health{run_uuid=\"$active_run\"} and on(stage, dep) (time() - bffi_dependency_last_probe_timestamp{run_uuid=\"$active_run\"} < 60)",
          "legendFormat": "{{stage}}/{{dep}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "stale",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "down",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "degraded",
                  "color": "orange"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "up",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Per-stage throughput",
      "datasource": {
