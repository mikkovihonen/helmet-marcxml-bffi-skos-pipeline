      },
      "targets": [
        {
          "refId": "A",
          "expr": "bffi_dependency_probe_latency_ms{run_uuid=\"$active_run\"}",
          "legendFormat": "{{stage}}/{{dep}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "active_run",
        "label": "active run",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "bffi-prometheus"
        },
        "query": "topk(1, bffi_stage_started_timestamp) by (run_uuid)",
        "regex": "/.*run_uuid=\"([^\"]+)\".*/",
        "refresh": 2,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {
          "selected": false,
          "text": "auto",
          "value": "auto"
        }
      }
    ]
  }
}
