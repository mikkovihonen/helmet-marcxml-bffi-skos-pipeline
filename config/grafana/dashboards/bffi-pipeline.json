{
  "title": "BFFI pipeline",
  "uid": "bffi-pipeline",
  "tags": [
    "bffi",
    "pipeline",
    "p-11"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 9,
      "type": "stat",
      "title": "M2 marc-to-bf",
      "description": "Current state of pipeline stage `m2` for the active run. Green=running, blue=done, grey=idle / not-yet-started. P-12 Phase E.",
      "datasource": {
        "type": "prometheus",
        "uid": "bffi-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bffi_stage_started_timestamp{stage=\"m2\",run_uuid=\"$active_run\"} - on(stage, run_uuid) (bffi_stage_ended_timestamp{stage=\"m2\",run_uuid=\"$active_run\"} or vector(0))",
          "legendFormat": "delta"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "idle",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 0.5
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "done",
                  "color": "blue"
                }
              }
            }
          ]
        }
      }
    },
