    {
      "id": 17,
      "type": "stat",
      "title": "M2 marc-to-bf",
      "description": "M2 marc-to-bf \u2014 cumulative entities processed (top) and current throughput in items/min (bottom). Active run only.",
      "datasource": {
        "type": "prometheus",
        "uid": "bffi-prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bffi_stage_entities_processed_total{stage=\"m2\",run_uuid=\"$active_run\"} and on(phase) topk(1, timestamp(bffi_stage_entities_processed_total{stage=\"m2\",run_uuid=\"$active_run\"}))",
          "legendFormat": "processed"
        },
        {
          "refId": "B",
          "expr": "bffi_stage_throughput_per_minute{stage=\"m2\",run_uuid=\"$active_run\"} and on(phase) topk(1, timestamp(bffi_stage_entities_processed_total{stage=\"m2\",run_uuid=\"$active_run\"}))",
          "legendFormat": "items/min"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area",
        "textMode": "value_and_name",
        "colorMode": "value",
        "orientation": "vertical"
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "\u2014",
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
