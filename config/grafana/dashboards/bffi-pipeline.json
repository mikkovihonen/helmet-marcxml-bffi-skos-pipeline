          "legendFormat": "{{stage}}/{{phase}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Watchdog event rate (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "bffi-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(bffi_watchdog_events_total{run_uuid=\"$active_run\"}[5m]) * 60",
          "legendFormat": "{{stage}}/{{event}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "/min"
        }
      }
    },
    {
      "id": 8,
